{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "nikin.design",
  "version": "5.0.0",
  "description": "Portfolio website for Nikin Nagewadia",
  "main": "eleventy.config.js",
  "type": "module",
  "scripts": {
    "watch:sass": "sass --watch src/scss/style.scss:src/_includes/style.css --style=compressed",
    "watch:eleventy": "eleventy --serve",
    "start": "npm run build:sass && concurrently \"npm run watch:sass\" \"npm run watch:eleventy\"",
    "build:sass": "sass src/scss/style.scss:src/_includes/style.css --style=compressed --no-source-map",
    "build": "npm run build:sass && eleventy"
  },
  "keywords": [],
  "author": "Nikin Nagewadia",
  "license": "ISC",
  "dependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-img": "^6.0.4",
    "luxon": "^3.7.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "clean-css": "^5.3.3",
    "concurrently": "^9.2.1",
    "html-minifier-terser": "^7.2.0",
    "netlify-plugin-cache": "^1.0.3",
    "sass": "^1.99.0",
    "terser": "^5.46.1"
  }
}
