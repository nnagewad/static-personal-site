{% macro card(url, title, description, icon, headingLevel="h3") %}
<div class="card">
  <div class="card-img">
    {% if icon %}{% include icon %}{% endif %}
  </div>
  <div class="card-details">
    <{{ headingLevel }} class="font-size-1"><a href="{{ url }}">{{ title }}</a></{{ headingLevel }}>
    {% if description %}<p>{{ description }}</p>{% endif %}
  </div>
</div>
{% endmacro %}