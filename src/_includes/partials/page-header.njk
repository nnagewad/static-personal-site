{% if layout != "layouts/home.njk" %}
  <nav class="home-link font-size--1">
    <svg xmlns="http://www.w3.org/2000/svg" class="navigation-icons" width="7.9" height="13.1" aria-hidden="true" focusable="false" viewBox="0 0 7.9 13.1"><polygon points="7.9 1.4 6.6 0 0 6.6 6.6 13.1 7.9 11.7 2.8 6.6 7.9 1.4"></polygon></svg>
    <a href="/">Home</a>
  </nav>
{% endif %}

<header class="page-header">
  {% if layout == "layouts/case-study.njk" %}
    <h1>
      <span class="headline-caption">Case study</span>
      <span class='font-size-2'>{{ title }}</span>
    </h1>
  {% else %}
    <h1 class='font-size-2'>{{ title }}</h1>
  {% endif %}
  {% if subTitle %}
    <p class='lead-paragraph'>{{ subTitle }}</p>
  {% endif %}
</header>